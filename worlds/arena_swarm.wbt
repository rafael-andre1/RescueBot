WorldInfo {
  basicTimeStep 32
}
Viewpoint {
  orientation -0.3714576357318767 -0.37673088126522425 0.8485829764717248 4.518781458128897
  position 0.0 22.0 22.0
}
TexturedBackground {
}
TexturedBackgroundLight {
}
Floor {
  size 9 7
  tileSize 1 1
}

# ───── Outer walls (9 × 7 bounding box) ────────────────────────────
