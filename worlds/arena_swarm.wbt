# ═══════════════════════════════════════════════════════════════════
#  Pingers — three coloured beacons in three far corners, one per channel
# ═══════════════════════════════════════════════════════════════════
Robot {
  translation 3.8 2.8 0.05
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 1 0 0
        emissiveColor 1 0 0
        roughness 0.2
        metalness 0
      }
      geometry Box { size 0.15 0.15 0.1 }
    }
    Emitter {
      name "emitter"
      channel 1
    }
  ]
  name "pinger_red"
  controller "signal_controller_swarm"
}
Robot {
  translation -3.8 2.8 0.05
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 1 1 0
        emissiveColor 1 1 0
        roughness 0.2
        metalness 0
      }
      geometry Box { size 0.15 0.15 0.1 }
    }
    Emitter {
      name "emitter"
      channel 2
    }
  ]
  name "pinger_yellow"
  controller "signal_controller_swarm"
}
Robot {
  translation 3.8 -2.8 0.05
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0 1 0
        emissiveColor 0 1 0
        roughness 0.2
        metalness 0
      }
      geometry Box { size 0.15 0.15 0.1 }
    }
    Emitter {
      name "emitter"
      channel 3
    }
  ]
  name "pinger_green"
  controller "signal_controller_swarm"
}

# ═══════════════════════════════════════════════════════════════════
#  Swarm scouts — three e-pucks near origin, triangle spacing to avoid
#  collisions, each tuned to its own pinger channel + colour.
# ═══════════════════════════════════════════════════════════════════
E-puck {
  translation 0.0 0.30 0.0
  rotation 0 0 1 0.582
  name "scout_red"
  controller "robot_controller_swarm"
  controllerArgs ["1" "red" "0.0" "0.30"]
  receiver_channel 1
  camera_fieldOfView 1.047
  camera_width 128
  camera_height 96
  turretSlot [
    Lidar {
      translation 0 0 0.02
      horizontalResolution 360
      fieldOfView 6.283185
      numberOfLayers 1
      maxRange 5
    }
    Display {
      name "map_display"
      width 400
      height 400
    }
    Compass {
      name "compass"
    }
  ]
}
E-puck {
  translation -0.26 -0.15 0.0
  rotation 0 0 1 2.447
  name "scout_yellow"
  controller "robot_controller_swarm"
  controllerArgs ["2" "yellow" "-0.26" "-0.15"]
  receiver_channel 2
  camera_fieldOfView 1.047
  camera_width 128
  camera_height 96
  turretSlot [
    Lidar {
      translation 0 0 0.02
      horizontalResolution 360
      fieldOfView 6.283185
      numberOfLayers 1
      maxRange 5
    }
    Display {
      name "map_display"
      width 400
      height 400
    }
    Compass {
      name "compass"
    }
  ]
}
E-puck {
  translation 0.26 -0.15 0.0
  rotation 0 0 1 -0.642
  name "scout_green"
  controller "robot_controller_swarm"
  controllerArgs ["3" "green" "0.26" "-0.15"]
  receiver_channel 3
  camera_fieldOfView 1.047
  camera_width 128
  camera_height 96
  turretSlot [
    Lidar {
      translation 0 0 0.02
      horizontalResolution 360
      fieldOfView 6.283185
      numberOfLayers 1
      maxRange 5
    }
    Display {
      name "map_display"
      width 400
      height 400
    }
    Compass {
      name "compass"
    }
  ]
}
